{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwarmClone Desktop",
  "description": "A Desktop Application For SwarmClone AI Framework",
  "version": "0.1.0",
  "copyright": "Copyright © 2025 SwarmClone and Contributors",
  "identifier": "com.swarmclone.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "swarmclone-desktop-app",
        "width": 1200,
        "height": 700,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.ico"
    ]
  }
}
